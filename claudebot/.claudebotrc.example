# .claudebotrc - Quick configuration file
# This file provides quick overrides for common settings
# Format: INI-style key=value pairs

# Server settings
host = localhost
port = 8765

# Agents
# agents = all
# timeout = 300

# Claude
# model = claude-3-5-sonnet-20241022

# Git
# auto_commit = false
# default_branch = main
